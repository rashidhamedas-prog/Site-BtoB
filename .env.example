# ============================================================
# Taranom B2B Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# App
NODE_ENV=production
PORT=4000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=taranom
DB_PASS=CHANGE_ME_STRONG_PASSWORD
DB_NAME=taranom_db
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=CHANGE_ME_REDIS_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES=7d

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=CHANGE_ME_MEILI_KEY

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_USER=taranom_minio
MINIO_PASS=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=taranom-products
# Public URL for browser-accessible images (production: https://poshaktaranom.com/media)
MINIO_PUBLIC_URL=http://localhost:9000/taranom-products

# Set DB_SYNC=true once on fresh server to create tables (then remove)
DB_SYNC=false

# Next.js (public — safe to expose to browser)
NEXT_PUBLIC_API_URL=https://api.poshaktaranom.com
NEXT_PUBLIC_SITE_URL=https://poshaktaranom.com
NEXT_PUBLIC_RETAIL_URL=https://poshaktaranom.ir

# Payment Gateways
ZARINPAL_MERCHANT_ID=CHANGE_ME
IDPAY_API_KEY=CHANGE_ME

# SMS (Kavenegar / IPPANEL)
SMS_API_KEY=CHANGE_ME
SMS_SENDER=CHANGE_ME

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHANNEL_ID=@toliditaranom

# CORS
ALLOWED_ORIGINS=https://poshaktaranom.com,https://poshaktaranom.ir
